# ==========================================
# AI Animation Factory - Environment Variables
# ==========================================

# ==========================================
# Core Settings
# ==========================================
NODE_ENV=development
API_PORT=3001
PORT=3001
API_URL=http://localhost:3001

# Frontend URL (used by Next.js web app)
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Logging
LOG_LEVEL=info

# Mock mode (set to true to use in-memory data without a real DB/Redis)
MOCK_MODE=false

# ==========================================
# Supabase (Database + Storage)
# Get from: https://supabase.com/dashboard/project/_/settings/api
# ==========================================
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# ==========================================
# Redis (Queue System)
# Option A: Upstash (Recommended for Vercel)
# Sign up: https://upstash.com
# ==========================================
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# Option B: Self-hosted / Windows Service (local dev)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ==========================================
# AI Services API Keys
# ==========================================

# OpenAI (for GPT-4)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key

# ElevenLabs (for Voice)
# Get from: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your-elevenlabs-key-here
ELEVENLABS_DEFAULT_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Runway (for Animation)
# Get from: https://runwayml.com/account/
RUNWAY_API_KEY=key-your-runway-key
RUNWAY_API_URL=https://api.runwayml.com/v1

# Mubert (for Music)
# Get from: https://mubert.com/pricing
MUBERT_API_KEY=your-mubert-key
MUBERT_LICENSE=your-mubert-license

# Google Gemini (Alternative to OpenAI)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# ==========================================
# Authentication
# ==========================================
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long
JWT_EXPIRY=7d

# ==========================================
# Local AI Microservices (Fixed Ports — Do NOT change)
# ==========================================

# ComfyUI — Image Generation (port 8188)
COMFYUI_URL=http://localhost:8188
NEXT_PUBLIC_COMFYUI_URL=http://localhost:8188

# MediaVoice Studio — Audio/Voice/Dubbing (port 8000)
MEDIAVORICE_URL=http://localhost:8000

# ==========================================
# Ollama (Local LLM - Optional)
# Install: https://ollama.ai  →  ollama pull llama3
# ==========================================
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# AI Provider selection: gemini | ollama | auto
# auto = Gemini first, Ollama as fallback
AI_PROVIDER=auto

# ==========================================
# Storage
# ==========================================
STORAGE_BUCKET=ai-animation-factory
STORAGE_PUBLIC_URL=https://your-project.supabase.co/storage/v1/object/public/ai-animation-factory

# ==========================================
# Generation Settings
# ==========================================
EPISODES_PER_HOUR=5
MAX_CONCURRENT_JOBS=10
SCENE_COUNT=8
VIDEO_DURATION_SECONDS=60

# ==========================================
# Optional: Monitoring
# ==========================================
# SENTRY_DSN=https://your-sentry-dsn.ingest.sentry.io/project-id

# ==========================================
# Optional: Analytics
# ==========================================
# POSTHOG_KEY=your-posthog-key
